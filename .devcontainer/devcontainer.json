{
	"name": "Django Development",
	"build": {
		"context": "..",
		"dockerfile": "Dockerfile"
	},
	"forwardPorts": [
		8000
	],
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylance"
			]
		}
	},
	"postCreateCommand": "pip install -r requirements.txt"
}